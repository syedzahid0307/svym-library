# Database (Neon Postgres)
DATABASE_URL=

# NextAuth
AUTH_SECRET=

# ImageKit (book covers / media)
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=

# Upstash (rate limiting + workflow scheduling)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
QSTASH_URL=
QSTASH_TOKEN=

# Resend (transactional email - welcome emails, overdue reminders)
RESEND_TOKEN=

# API endpoints used by the onboarding workflow to call back into this app
NEXT_PUBLIC_API_ENDPOINT=
NEXT_PUBLIC_PROD_API_ENDPOINT=

# Shared secret that gates /api/cron/overdue-reminders so it can't be
# triggered by anyone who finds the URL. If deploying on Vercel and using
# vercel.json's "crons" entry, Vercel automatically sends this value as
# "Authorization: Bearer <CRON_SECRET>" on scheduled requests once this
# env var is set - no extra config needed beyond setting it here.
CRON_SECRET=
